[node name="Texto" type="RichTextLabel" parent="Info/Pag38" unique_id=907440897]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Humberto es un hacker que ha creado un punto de acceso Wifi gratuito en la iglesia, lo llamó \"red hermandad de los cielos\" un nombre que suena amable y bondadoso. Cuando alguien se conecte, Humberto podrá ver el tráfico de la red, pedir credenciales para conectarse, robar cookies, obtener información de formularios no cifrados, redirigir a páginas falsas manipulando el DNS, etc"
