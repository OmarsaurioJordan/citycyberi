offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Laura es una artista, y sabe que debe separar su vida privada de su portafolio público, para ello tiene dos cuentas, una donde sube sus fotos, ha colocado restricción de acceso a personas de confianza, otra donde publica sus dibujos y es de alcance público. Así mismo tiene una tarjeta de presentación con sus datos enlazados a dicha cuenta pública, puesto que trabaja como diseñadora"
