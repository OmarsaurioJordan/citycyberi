[node name="Texto" type="RichTextLabel" parent="Info/Pag8" unique_id=796759185]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Hoy Arnold cree que tiene suerte, volviendo del gimnasio ha encontrado en las escaleras una memoria USB, que según etiqueta es de su vecina Maribel, cree que es la oportunidad para hablarle pero primero... va a revisarla sin saber que está infectada, Arnold cae mediante la técnica de ingeniería social llamada \"baiting\", donde el hacker pone un ansuelo atractivo, por ejemplo, un juego corrupto"
