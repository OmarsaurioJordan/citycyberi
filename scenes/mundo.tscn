offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Willy es un hacker que vende acceso a cuentas, usualmente usa Password Spraying (probando passwords comunes en muchas cuentas), pero esta vez intenta Credential Stuffing con las varias redes sociales y cuentas de Karen, pues ha logrado hacerse con un password que ella usa en una aplicación de baja seguridad. Willy espera que ella use esa misma contraseña en otros sitios"
