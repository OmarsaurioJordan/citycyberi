layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "En su vida Karen adora actualizar sus computadoras y celulares constantemente, le han criticado de pertenecer a la sociedad de consumo masivo, pero sea el caso o no, actualizar el hardware (y también el software) es un paso extra de seguridad, las empresas suelen corregir vulnerabilidades antes de que los hackers las exploten, para ellos es importante saber qué dispositivos usas"
