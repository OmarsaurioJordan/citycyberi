layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Ésta es la habitación privada de Maribel, lo que ella desconoce es que su fiel dispositivo móvil ha sido infectado con un RAT (Remote Acces Trojan), todo por haber descargado un videojuego pirata, ahora su cámara la espía y los hackers pueden sobornarla con pagos a cambio de no difundir sus fotos íntimas por la web. Además de los cuidados en la navegación y ejecución, es bueno tapar las cámaras"
