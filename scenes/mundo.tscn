[node name="Texto" type="RichTextLabel" parent="Info/Pag43" unique_id=305738033]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "¿Cómo protejo mi cuenta? Se preguntaba Cony, en vista de que una contraseña puede ser robada o adivinada, una opción que le recomendaron era la autenticación en dos pasos, así que luego de ingresar su contraseña al computador, debe verificar un SMS (o un token en una App) en su celular, pero yendo más allá, le recomendaron usar las firmas biométricas (huellas, cara, iris)"
