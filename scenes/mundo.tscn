[node name="Texto" type="RichTextLabel" parent="Info/Pag14" unique_id=657451730]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Acá observamos a Mikey, este sujeto se cuida del Malware (software malicioso), usando exclusivamente páginas web oficiales: Youtube, Wikipedia, Netflix, Facebook, Amazon, etc. No le gusta buscar cosas al azar en Google y darles clic, por ejemplo, \"programa para fusionar archivos PDF online\", probablemente encuentre un sin fín de herramientas gratuitas, pero suelen ser páginas poco seguras"
