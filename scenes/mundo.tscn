offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Mr Z, experto en cyberseguridad, enseña a tres administradores de empresas la importancia de las auditorías (revisiónes de seguridad periódicas), el cumplimiento de las normativas estándar, como ISO 27000, la importancia de conocer la ingeniería social (manipulación psicológica) y que los sistemas software deben tener Roles + Permisos bien configurados, con historial de registros de cambios"
