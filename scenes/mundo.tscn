offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Los empresarios Jean y Freddy han sacado su nuevo producto software, un grabador de imágenes GIF en pantalla llamado Gigimu, no requiere sesiónes ni bases de datos, es un sistema simple, lo que no saben es que uno de sus trabajadores, Brandon ha infectado el ejecutable con Malware Spyware, ahora sus clientes y su empresa se hallan en riesgo, Brandon es el encargado de la cyberseguridad"
