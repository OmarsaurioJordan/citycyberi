offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Hoy Chris te aconseja a proteger tu información con multicuentas, puedes tener varios correos cada uno con distinta contraseña, uno para juegos, otro para redes sociales, otro para guardar tus archivos en secreto y otro para trabajo y pagos. Chris dice que no olvides configurar bien cada uno, y utilizar contraseñas largas, con números, letras mayúsculas y minúsculas y hasta caracteres raros"
