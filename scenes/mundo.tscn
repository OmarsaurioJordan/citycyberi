offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Pobre Jeremy, se quemó en un accidente dentro de la fábrica hace unos meses, sería terrible que un ataque de hackeo afectara la máquinaria del hospital. Por suerte, usan una Intranet (como una red aislada o mini internet que administra los procesos internos), así, el Internet con el que revisan sus celulares y navegan por redes sociales está separado de el sistema que lo mantiene vivo"
