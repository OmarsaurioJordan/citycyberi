[node name="Texto" type="RichTextLabel" parent="Info/Pag11" unique_id=1035388303]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "En la punta de este edificio vive Jack, qién está alegre porque logró hacerse con un archivo ZIP secreto de Arnold, pero tiene contraseña ¿Cómo se abre un archivo local con contraseña? Vemos a Jack usando el algoritmo de \"fuerza bruta\" (ya se usa poco en logins web). Se trata de algorítmicamente probar miles de contraseñas por minuto, permutar hasta hallar la adecuada"
