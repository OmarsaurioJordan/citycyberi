offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Recientemente Ana fué testigo de comentarios hechos en la red social de su madre Nancy en su nombre, decidió pagarle a su madre un buen Antivirus que incluye VPN y Firewall, lo que significa que además de identificar Malware, el producto puede cifrar el tráfico de red y hacer parecer que te conectas desde otro lugar (VPN) y bloquear conexiónes extrañas o no solicitadas (Firewall)"
