[node name="Texto" type="RichTextLabel" parent="Info/Pag3" unique_id=354979443]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "El restaurante Monchis lleva solo un día inaugurando su página web, y la misma ha colapsado ¿Será que tuvo tantos usuarios? No, el tecnólogo Arturo nota que se trata de un ataque DDoS, en el cuál se satura el sistema con una cantidad torrencial de solicitudes, muchas provenientes de computadoras infectadas con Troyanos Botnet. Así los hackers bloquean la página o explotan vulnerabilidades"
