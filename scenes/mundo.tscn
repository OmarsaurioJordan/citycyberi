offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Don Cerdonio conoce un truco para corroborar la integridad del software (especialmente el pirata, si, cosa de cerdos), cuando una empresa lanza su producto usualmente comparte un hash (ej: MD5), una vez descargado Cerdonio calcula el hash, si este coincide con el original, el programa está intacto, tanto en errores como en hacks, pues es muy difícil modificar algo y hacer que los hash coincidan"
