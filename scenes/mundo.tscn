offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Estamos en el restaurante Monchis, Javier el encargado está recibiendo una llamada tipo Pretexting + Deepfake (urgencia y autoridad + suplantación de identidad con voz por IA), de parte de su jefa Miriam, la esposa de Oswaldo, dónde le solicita formal y autoritariamente mover el dinero a su cuenta, Javier como es de esperarse obedece sin saber que lo moverá a una cuenta falsa"
