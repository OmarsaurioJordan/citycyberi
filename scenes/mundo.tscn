[node name="Texto" type="RichTextLabel" parent="Info/Pag7" unique_id=1058547809]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Veamos este caso, un hippie urbano, se llama Patricio y sabe que la mejor forma de ser inmune al hackeo es no usar máquinas, cuánta razón tiene, el problema es que estamos en una sociedad sistematizada ¿Cómo identificarse parasolicitar servicios? Se aislará de lo que el mundo digital ofrece, experiencias que pueden mezclarse con lo natural, pero ser invisible también es válido"
