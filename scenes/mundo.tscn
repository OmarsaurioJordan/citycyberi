[node name="Texto" type="RichTextLabel" parent="Info/Pag5" unique_id=12702018]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "En una cómoda suit urbana vive Julio, él tiene dos computadores, uno para trabajar, usar sus redes sociales y pagar sus cuentas, otro para divertirse por ejemplo viendo películas piratas, en este pequeño computador nunca hace cosas importantes, aunque aún existe un riesgo por la cercanía vía mismo Wifi, Julio se siente tranquilo, pues el aislamiento hardware es mucho mejor que una VM"
