offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Zuko y Katara están en la iglesia flirteando, ellos conocían el Wifi oficial del lugar, aún así sufren un ataque MITM (man in the middle), Aurelio en la misma red trata de obtener sus mensajes, por suerte ellos se aseguran de navegar en páinas con HTTPS (nunca HTTP), evitan comprar cosas o logearse en esa red, además se comunican con cifrado de extremo a extremo, ej: Telegram"
