[node name="Texto" type="RichTextLabel" parent="Info/Pag13" unique_id=976127834]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "El olor a humo ha llamado la atención del técnico Carlos, la maquinaria de la fábrica parece haber sido afectada por un ataque al software, los hackeos avanzados pueden afectar los sistemas SCADA, PLC (programmable logic controller), RTU (remote terminal units), etc de los sistemas industriales. También los hardware domésticos pueden ser dañados con el conocimiento adecuado"
