offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Un tipo de Malware Troyano es el CryptoJacking, Angela está confundida viendo al computador de su oficina funcionar a tope, ralentizado aún cuando no hay nada abierto, lo que sucede es que el aparato está siendo usado con fines ajenos, los hackers que minan BitCoin necesitan muchas CPUs y GPUs trabajando para ellos, es más rentable usar las ajenas que mantener una granja de computadoras"
