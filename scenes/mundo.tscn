[node name="Texto" type="RichTextLabel" parent="Info/Pag40" unique_id=907070493]
layout_mode = 0
offset_left = 399.0
offset_top = 20.0
offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Diana es una famosa deportista, ahora está sacándose una foto para sus redes sociales, donde se ve su trofeo de oro, la altura a la que se encuentra en su edificio, y sin saberlo está dando su ubicación, pues observamos cláramente la cúpula de la iglesia. Un grupo criminal aún sin habilidades de hackeo, mediante Stalkeo podría saber el mejor momento para saltarla o robar su trofeo"
