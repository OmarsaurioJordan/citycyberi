offset_right = 1124.0
offset_bottom = 253.0
mouse_filter = 2
theme = ExtResource("1_kxyy5")
text = "Mientras Rodrigo está en su casa, no sabe que en esta sucursal telefónica un tal Ramiro se está haciendo pasar por él, usando ingeniería social engaña a los empleados para obtener su supuesto número robado de vuelta, su SIM, con ello el hacker podrá llevar a cabo verificaciónes en dos pasos que requieren el envío de SMS o tokens bancarios, esto se llama \"SIM Swapping\""
